system:
    instructions: |
        You are an AI Agent.
    messages:
        welcome: |
            Hi! Welcome to the Agentforce Demo. I can help you select a topic and view its description. How can I help?
        error: "Something went wrong. Try again."

config:
    agent_label: "Topic Demo Agent"
    agent_template: "EmployeeCopilot__AgentforceEmployeeAgent"
    developer_name: "TopicDemoAgent"
    agent_type: "AgentforceEmployeeAgent"
    description: "Demo agent that fetches topics using Custom Lightning Types and displays their descriptions."

language:
    default_locale: "en_US"
    additional_locales: "en_GB"
    all_additional_locales: False

variables:

start_agent agent_router:
    label: "Agent Router"
    description: "Welcome the user and determine the appropriate subagent based on user input"
    model_config:
        model: "model://sfdc_ai__DefaultEinsteinHyperClassifier"
    reasoning:
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.
        actions:
            go_to_Performing_Action_Topic: @utils.transition to @subagent.Performing_Action_Topic

subagent Performing_Action_Topic:
    label: "Performing Action Topic"
    description: "Prompts the user to select a topic and displays the description of the selected topic."
    reasoning:
        instructions: ->
            | When the user wants to select a topic or view a topic description, execute the Get_Topic_Description action.
            | This action will display a selection component. Wait for the user to select an option and submit it.
        actions:
            Get_Topic_Description: @actions.Get_Topic_Description
                with topicInput = ...
    actions:
        Get_Topic_Description:
            description: "Returns the description for a given topic type"
            label: "Get Topic Description"
            require_user_confirmation: False
            include_in_progress_indicator: False
            source: "Get_Topic_Description"
            target: "apex://TopicDescAction"
            inputs:
                "topicInput": object
                    description: "The topic selected by the user"
                    label: "Topic Input"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "c__topicSelection"
            outputs:
                "resultData": object
                    description: "The wrapper for topic description"
                    label: "Topic Desc Output"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "c__topicDescription"
